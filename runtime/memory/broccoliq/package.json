{
  "name": "@noorm/broccoliq",
  "version": "2.3.0",
  "type": "module",
  "private": false,
  "description": "BroccoliQ - Sharded Sovereign Hive Architecture (Level 11 Axiomatic Reliability)",
  "main": "./dist/infrastructure/index.js",
  "types": "./dist/infrastructure/index.d.ts",
  "exports": {
    ".": "./dist/infrastructure/index.js",
    "./pool": "./dist/infrastructure/db/pool/index.js",
    "./queue": "./dist/infrastructure/queue/SqliteQueue.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "SECURITY.md"
  ],
  "engines": {
    "node": ">=18.0.0",
    "bun": ">=1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cardsorting/broccoliq.git"
  },
  "bugs": {
    "url": "https://github.com/cardsorting/broccoliq/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "benchmark": "npx tsx ./infrastructure/db/Benchmark.ts",
    "update-kb": "npx tsx ./infrastructure/db/PopulateKnowledge.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "kysely": "^0.28.2",
    "kysely-bun-sqlite": "^0.4.0"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/better-sqlite3": "^7.6.12"
  },
  "license": "MIT"
}