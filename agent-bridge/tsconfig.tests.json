{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "tests",
    "outDir": "dist/tests",
    "declaration": false,
    "declarationMap": false,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "../dist/index.js": [
        "src/index.ts"
      ],
      "../dist/client/*": [
        "src/client/*"
      ],
      "../dist/contracts/*": [
        "src/contracts/*"
      ],
      "../dist/adapters/*": [
        "src/adapters/*"
      ],
      "../dist/workflows/*": [
        "src/workflows/*"
      ]
    }
  },
  "include": [
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
