{
  "name": "@dietcode/agent-bridge",
  "version": "1.0.0",
  "description": "Stable client-facing bridge between external agents and the DietCode runtime",
  "type": "module",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "dietcode-agent-client": "./dist/cli/dietcode-agent-client.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/MockRpcTransport.d.ts",
      "import": "./dist/testing/MockRpcTransport.js"
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.tests.json && node scripts/fix-test-imports.mjs",
    "test": "npm run build && npm run test:fast && node --test dist/tests/bridge.packaging.test.js",
    "test:fast": "node --test dist/tests/bridge.capabilities.test.js dist/tests/bridge.safePatchFile.test.js dist/tests/bridge.staleRecovery.test.js dist/tests/bridge.partialResults.test.js",
    "cli": "node dist/cli/dietcode-agent-client.js",
    "test:live": "node --test --test-concurrency=1 dist/tests/bridge.live.test.js dist/tests/bridge.live.workflows.test.js"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.2"
  }
}
