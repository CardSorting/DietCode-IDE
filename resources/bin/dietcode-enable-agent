#!/bin/bash
# DietCode bundled agent integration — delegates to trust-safe Python controller.
set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
APP_BUNDLE="$(cd "$DIR/../../.." && pwd)"

if [[ -z "${DIETCODE_APP_BUNDLE:-}" && -d "${APP_BUNDLE}/Contents/MacOS" ]]; then
  export DIETCODE_APP_BUNDLE="${APP_BUNDLE}"
fi

PY_SCRIPT="${DIR}/dietcode-enable-agent.py"
if [[ ! -f "${PY_SCRIPT}" ]]; then
  REPO_ROOT="$(cd "${APP_BUNDLE}/../../.." 2>/dev/null && pwd || true)"
  if [[ -f "${REPO_ROOT}/scripts/dietcode_enable_agent.py" ]]; then
    PY_SCRIPT="${REPO_ROOT}/scripts/dietcode_enable_agent.py"
  fi
fi

if [[ ! -f "${PY_SCRIPT}" ]]; then
  echo "dietcode-enable-agent controller missing. Reinstall DietCode.app." >&2
  exit 1
fi

exec python3 "${PY_SCRIPT}" "$@"
